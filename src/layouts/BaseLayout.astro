---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  pageType?: 'WebPage' | 'AboutPage' | 'ContactPage' | 'CollectionPage' | 'Article';
}

const {
  title,
  description = "Delegate the hard thinking. We survey, map, analyse, and deliver a defensible answer your board reads in fifteen minutes. Cloud cost, cyber resilience, AI integration. Fixed-scope, decision-grade.",
  canonical,
  ogImage = '/og-image.png',
  pageType = 'WebPage',
} = Astro.props;

const fullTitle = title.includes('Thinking Machine') ? title : `${title} — Thinking Machine`;
// Strip the .html / index.html suffix that build.format='file' bakes into
// Astro.url.pathname. The sitemap already serves the clean path; the
// canonical, og:url, and JSON-LD url need to match the served URL exactly.
const cleanPath = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '');
const canonicalURL = canonical || new URL(cleanPath, Astro.site).toString();
const siteUrl = Astro.site?.toString() ?? 'https://thinkingmachine.uk/';
const ogImageURL = new URL(ogImage, Astro.site).toString();

// JSON-LD structured data (graph). High SEO + AI-visibility value in 2026
// (ChatGPT, Perplexity, Gemini all parse Organization + Service nodes).
const ldJson = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': `${siteUrl}#organization`,
      name: 'Thinking Machine d.o.o.',
      legalName: 'Thinking Machine d.o.o.',
      alternateName: 'Thinking Machine',
      url: siteUrl,
      logo: new URL('/favicon.svg', Astro.site).toString(),
      foundingDate: '2022',
      slogan: 'Delegate the hard thinking. We hand back a defensible answer.',
      description: 'Boutique strategic engineering advisory: cloud cost & FinOps strategy, cyber resilience & NFR compliance, AI integration for established systems. We survey, map, analyse, and deliver fixed-scope, decision-grade work in two to four weeks.',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Zagorska ulica 11',
        addressLocality: 'Zagreb',
        postalCode: '10000',
        addressCountry: 'HR',
      },
      areaServed: [
        { '@type': 'AdministrativeArea', name: 'European Union' },
        { '@type': 'Country', name: 'Croatia' },
        { '@type': 'Country', name: 'Germany' },
        { '@type': 'Country', name: 'Norway' },
      ],
      knowsAbout: [
        'Cloud cost optimisation',
        'FinOps',
        'Microsoft Azure',
        'Amazon Web Services',
        'Google Cloud Platform',
        'NIS2 Directive compliance',
        'EU Cyber Resilience Act',
        'Non-functional requirements',
        'Procurement due diligence',
        'AI integration',
        'Retrieval-Augmented Generation',
        'Model Context Protocol',
        'On-premises Large Language Models',
        'Domain-Driven Design',
        'Microservices architecture',
        'C# .NET architecture',
        'Industrial IoT',
        'Healthcare information systems',
        'Telecommunications',
        'GDPR Article 9 special-category data',
        'European Health Data Space (EHDS)',
        'HL7 FHIR R4 interoperability',
        'EN 62304 medical-device software lifecycle',
        'ISO 14971 medical risk management',
        'ISO 27001 / 27799 healthcare ISMS',
        'Gematik telematics infrastructure (Germany)',
        'BSI C5 cloud security framework (Germany)',
        'Self-hosted speech-to-text and ASR',
        'Whisper-family ASR deployment',
        'Speaker diarization',
        'GPU sizing for inference workloads',
        'Six-dimension cost modelling for media platforms',
        'Codec-driven storage cost engineering',
        'SQL Server licensing on cloud',
        'WebRTC architecture',
        'Selective Forwarding Unit (SFU)',
        'End-to-end media encryption (SFrame)',
        'Real-time signaling (SignalR / WebSocket)',
        'On-premises media-server deployment',
        'Region-of-interest video encoding',
        'Neural noise cancellation (edge-side audio enhancement)',
        'Adaptive recording strategies',
        'Edge-side audio/video processing',
      ],
      identifier: [
        { '@type': 'PropertyValue', propertyID: 'OIB', value: '62472822484' },
        { '@type': 'PropertyValue', propertyID: 'MB', value: '5637031' },
      ],
      sameAs: [
        'https://www.linkedin.com/in/bruno-bo%C5%BEi%C4%87-74245876/',
        'https://github.com/brunobozic',
      ],
      founder: {
        '@type': 'Person',
        name: 'Bruno Božić',
        jobTitle: 'Founder & Principal Advisor',
        sameAs: [
          'https://www.linkedin.com/in/bruno-bo%C5%BEi%C4%87-74245876/',
          'https://github.com/brunobozic',
        ],
      },
      makesOffer: [
        {
          '@type': 'Offer',
          name: 'Cloud cost & FinOps strategy',
          description: 'Board-grade cost assessments anchored on published frameworks. Triangulated baselines, multi-scenario reserved-instance modelling, vendor-side pricing playbooks.',
          category: 'Cloud cost advisory',
        },
        {
          '@type': 'Offer',
          name: 'Cyber resilience & NFR advisory',
          description: 'NIS2 readiness, Azure-native security architecture, and structured NFR responses for procurement and pre-contract due diligence.',
          category: 'Cyber resilience advisory',
        },
        {
          '@type': 'Offer',
          name: 'AI integration for established systems',
          description: 'MCP control layers, RAG over enterprise knowledge bases, on-premises LLM infrastructure, LLM-assisted legacy modernisation.',
          category: 'AI integration advisory',
        },
      ],
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'Sales',
        email: 'hello@thinkingmachine.uk',
        availableLanguage: ['en', 'hr'],
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: 'Thinking Machine',
      publisher: { '@id': `${siteUrl}#organization` },
      inLanguage: 'en',
    },
    {
      '@type': pageType,
      '@id': canonicalURL,
      url: canonicalURL,
      name: fullTitle,
      description,
      isPartOf: { '@id': `${siteUrl}#website` },
      about: { '@id': `${siteUrl}#organization` },
      inLanguage: 'en',
    },
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Thinking Machine" />
    <meta property="og:locale" content="en_GB" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {/* Author / publisher */}
    <meta name="author" content="Bruno Božić" />
    <meta name="theme-color" content="#1E3A8A" />

    {/* Fonts — preconnect + display swap */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap"
    />

    {/* JSON-LD structured data — for SEO + AI visibility (ChatGPT/Perplexity/Gemini parse this) */}
    <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
