---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../i18n/paths';

export interface Props {
  study: CollectionEntry<'case-studies'>;
  locale?: Locale;
}

const { study, locale = 'en' } = Astro.props;
const { title, sector, engagementType, year, summary } = study.data;

// Slug shape:
//   EN studies: 'foo-bar'                → /work/foo-bar
//   DE studies: 'de/foo-bar'             → /de/work/foo-bar
//   HR studies: 'hr/foo-bar'             → /hr/work/foo-bar
const bareSlug = study.slug.replace(/^(de|hr)\//, '');
const href = locale === 'en' ? `/work/${bareSlug}` : `/${locale}/work/${bareSlug}`;

const ctaByLocale: Record<Locale, string> = {
  en: 'Read case study',
  de: 'Fallstudie lesen',
  hr: 'Pročitaj studiju slučaja',
};
const cta = ctaByLocale[locale];
---
<article class="border border-ink-200 bg-white p-7 md:p-8 card-lift group">
  <div class="text-xs uppercase tracking-wider text-ink-500 mb-3">
    {engagementType} · {sector} · {year}
  </div>
  <h3 class="font-serif text-2xl text-ink-900 leading-tight">
    <a href={href} class="no-underline group-hover:text-accent-800 transition-colors">{title}</a>
  </h3>
  <p class="mt-4 text-ink-700">{summary}</p>
  <a href={href} class="inline-flex items-center gap-1 mt-5 text-accent-700 no-underline text-sm group/link">
    {cta}
    <span class="transition-transform group-hover/link:translate-x-1">→</span>
  </a>
</article>
