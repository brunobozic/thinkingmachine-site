---
import { buildLocaleUrl, SUPPORTED_LOCALES, type Locale } from '../i18n/paths';

const year = new Date().getFullYear();

// Detect the current locale from the URL path so the footer can produce
// locale-correct hrefs and labels without each parent passing it in.
// Astro.url.pathname can carry a '.html' / '/index.html' suffix when
// build.format='file' — strip it first, then split.
const cleanPath = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '');
const segs = cleanPath.replace(/^\//, '').split('/');
const currentLocale: Locale = (SUPPORTED_LOCALES as readonly string[]).includes(segs[0])
  ? (segs[0] as Locale)
  : 'en';

const t = {
  en: {
    tagline: 'Strategic engineering advisory for compliance-sensitive enterprises.',
    site: 'Site',
    services: 'Services', work: 'Work', notes: 'Notes', about: 'About', contact: 'Contact',
    office: 'Office', city: 'Zagreb, Croatia', founded: 'Founded 2022',
    rights: 'All rights reserved.',
    notrackers: 'No trackers. No newsletter. No CRM.',
    getintouch: 'Get in touch →',
    linkedinLabel: 'Bruno Božić on LinkedIn',
    githubLabel: 'brunobozic on GitHub',
  },
  de: {
    tagline: 'Strategische Engineering-Beratung für Compliance-sensitive Unternehmen.',
    site: 'Seite',
    services: 'Leistungen', work: 'Arbeit', notes: 'Notizen', about: 'Über uns', contact: 'Kontakt',
    office: 'Büro', city: 'Zagreb, Kroatien', founded: 'Gegründet 2022',
    rights: 'Alle Rechte vorbehalten.',
    notrackers: 'Keine Tracker. Kein Newsletter. Kein CRM.',
    getintouch: 'Kontakt aufnehmen →',
    linkedinLabel: 'Bruno Božić auf LinkedIn',
    githubLabel: 'brunobozic auf GitHub',
  },
  hr: {
    tagline: 'Strateško inženjersko savjetovanje za poduzeća osjetljiva na sukladnost.',
    site: 'Stranica',
    services: 'Usluge', work: 'Rad', notes: 'Bilješke', about: 'O nama', contact: 'Kontakt',
    office: 'Ured', city: 'Zagreb, Hrvatska', founded: 'Osnovano 2022.',
    rights: 'Sva prava pridržana.',
    notrackers: 'Bez trackera. Bez newslettera. Bez CRM-a.',
    getintouch: 'Javite nam se →',
    linkedinLabel: 'Bruno Božić na LinkedInu',
    githubLabel: 'brunobozic na GitHubu',
  },
}[currentLocale];

// Build a locale-prefixed URL for paths that ARE translated; for
// untranslated paths, return the canonical EN URL so the footer never
// dead-links to the locale home.
const prefix = currentLocale === 'en' ? '' : `/${currentLocale}`;
const link = (path: string) => `${prefix}${path}`;
const linkUntranslated = (path: string) => path;
---
<footer class="mt-24 border-t border-ink-200 bg-ink-100/40">
  <div class="container-page py-12 grid gap-10 md:grid-cols-3 text-sm text-ink-700">
    <div>
      <div class="font-serif text-lg text-ink-900">Thinking Machine d.o.o.</div>
      <p class="mt-2 max-w-xs">{t.tagline}</p>
    </div>

    <nav class="flex flex-col gap-2">
      <span class="text-ink-500 uppercase tracking-wider text-xs mb-1">{t.site}</span>
      <a href={link('/services')} class="no-underline hover:text-ink-900">{t.services}</a>
      <a href={link('/work')}     class="no-underline hover:text-ink-900">{t.work}</a>
      <a href={linkUntranslated('/notes')}    class="no-underline hover:text-ink-900">{t.notes}</a>
      <a href={link('/about')}    class="no-underline hover:text-ink-900">{t.about}</a>
      <a href={link('/contact')}  class="no-underline hover:text-ink-900">{t.contact}</a>
    </nav>

    <div class="flex flex-col gap-2">
      <span class="text-ink-500 uppercase tracking-wider text-xs mb-1">{t.office}</span>
      <span>{t.city}</span>
      <span>{t.founded}</span>
      <span class="text-ink-500">OIB: <span class="text-ink-700">62472822484</span></span>
      <div class="flex items-center gap-3 mt-3">
        <a href="https://www.linkedin.com/in/bruno-bo%C5%BEi%C4%87-74245876/" rel="noopener" class="text-ink-500 hover:text-ink-900 no-underline" aria-label={t.linkedinLabel}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43c-1.14 0-2.07-.93-2.07-2.07 0-1.14.93-2.07 2.07-2.07 1.14 0 2.07.93 2.07 2.07 0 1.14-.93 2.07-2.07 2.07Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0Z"/></svg>
        </a>
        <a href="https://github.com/brunobozic" rel="noopener" class="text-ink-500 hover:text-ink-900 no-underline" aria-label={t.githubLabel}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .3a12 12 0 0 0-3.79 23.4c.6.11.82-.26.82-.58v-2c-3.34.73-4.04-1.61-4.04-1.61-.55-1.4-1.34-1.78-1.34-1.78-1.09-.74.08-.73.08-.73 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .1-.78.42-1.31.76-1.61-2.66-.31-5.46-1.34-5.46-5.96 0-1.32.47-2.39 1.24-3.23-.13-.31-.54-1.55.11-3.22 0 0 1.01-.32 3.31 1.23a11.5 11.5 0 0 1 6.04 0c2.3-1.55 3.31-1.23 3.31-1.23.65 1.67.24 2.91.12 3.22.77.84 1.24 1.91 1.24 3.23 0 4.63-2.81 5.65-5.49 5.95.43.37.81 1.1.81 2.21v3.28c0 .32.21.7.83.58A12 12 0 0 0 12 .3Z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="container-page pb-8 flex flex-col md:flex-row md:justify-between gap-3 text-xs text-ink-500">
    <span>© {year} Thinking Machine d.o.o. {t.rights}</span>
    <span>
      {t.notrackers} <a href={link('/contact')} class="no-underline text-ink-700 hover:text-ink-900">{t.getintouch}</a>
    </span>
  </div>
</footer>
