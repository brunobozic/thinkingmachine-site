---
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-ink-200 bg-ink-100/40">
  <div class="container-page py-12 grid gap-10 md:grid-cols-3 text-sm text-ink-700">
    <div>
      <div class="font-serif text-lg text-ink-900">Thinking Machine d.o.o.</div>
      <p class="mt-2 max-w-xs">
        Strategic engineering advisory for compliance-sensitive enterprises.
      </p>
    </div>

    <nav class="flex flex-col gap-2">
      <span class="text-ink-500 uppercase tracking-wider text-xs mb-1">Site</span>
      <a href="/services" class="no-underline hover:text-ink-900">Services</a>
      <a href="/work" class="no-underline hover:text-ink-900">Work</a>
      <a href="/about" class="no-underline hover:text-ink-900">About</a>
      <a href="/contact" class="no-underline hover:text-ink-900">Contact</a>
    </nav>

    <div class="flex flex-col gap-2">
      <span class="text-ink-500 uppercase tracking-wider text-xs mb-1">Office</span>
      <span>Zagreb, Croatia</span>
      <span>Founded 2022</span>
      <span class="text-ink-500">OIB: <span class="text-ink-700">62472822484</span></span>
    </div>
  </div>

  <div class="container-page pb-8 flex flex-col md:flex-row md:justify-between gap-3 text-xs text-ink-500">
    <span>© {year} Thinking Machine d.o.o. All rights reserved.</span>
    <span>
      No trackers. No newsletter. No CRM. <a href="/contact" class="no-underline text-ink-700 hover:text-ink-900">Get in touch →</a>
    </span>
  </div>
</footer>
