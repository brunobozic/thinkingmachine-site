---
// CaseStudyNumbersStrip — reusable four-cell defensible-numbers strip used
// across case studies for visual register parity.
//
// Every value passed must already appear in the case-study body. This
// component is not a place to invent metrics.
//
// Props:
//   caption: the small uppercase header above the strip
//   note:    the small caption below the strip
//   cells:   array of exactly 4 { value, label, sublabel } objects
//
// Locale-agnostic: the parent passes already-translated strings.

export interface Cell {
  value: string;
  label: string;
  sublabel: string;
}

export interface Props {
  caption: string;
  note: string;
  cells: [Cell, Cell, Cell, Cell];
}

const { caption, note, cells } = Astro.props;
---
<figure class="my-10">
  <figcaption class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4 font-medium">{caption}</figcaption>
  <div class="border border-ink-200 bg-white p-6 md:p-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {cells.map(c => (
        <div>
          <div class="font-serif text-5xl text-accent-700 leading-none">{c.value}</div>
          <div class="mt-3 text-sm text-ink-700 leading-snug">{c.label}</div>
          <div class="mt-1 text-xs text-ink-500">{c.sublabel}</div>
        </div>
      ))}
    </div>
  </div>
  <p class="mt-3 text-xs text-ink-500">{note}</p>
</figure>
