---
// SupplyChainCaseStudyCharts — three inline-SVG charts for the
// supply-chain-iac-saas-platform case study.
//
// All numbers shown here are substantiated:
//   - 85: Bruno's commits on the IaC repo across all branches
//   - 4 : artifact channels mediated by internal registries (Composer/Satis,
//         npm/Verdaccio, container/GitLab Registry, SQL/Redgate)
//   - 8 : distinct VM roles in the Semaphore catalogue (router, semaphore,
//         gitlab, dev, customer, metabase, grafana, satis)
//   - 5+: years of legacy codebase reconstructed (built ~2018–2019,
//         worked on in 2024)
//   - time allocation: engineer's own time, not client performance metrics.

import type { Locale } from '../i18n/paths';

export interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;

const t = {
  en: {
    cap1: 'By the numbers',
    note1: 'All four numbers are extracted from the engagement\'s four repositories or from the deployed infrastructure inventory; none are derived from client-measured performance outcomes.',
    n1: ['~178', 'commits across the four repositories', 'orchestration · reverse proxy · PostgreSQL · analytics'],
    n2: ['4',  'artifact channels mediated by internal registries', 'Composer · npm · SQL · container'],
    n3: ['8',  'VM roles in the Semaphore catalogue', 'router · orchestrator · registry · dev · customer · BI · metrics · packages'],
    n4: ['4', 'repositories revived end-to-end', 'codebase 5+ years old · originally authored 2018–2019'],
    cap2: 'Software supply chain · internal trust roots',
    colA: 'PUBLIC SOURCE', colB: 'INTERNAL TRUST ROOT', colC: 'TENANT BUILD',
    pub: ['Packagist (public)', 'npm (public)', 'Public OCI registries', 'Ad-hoc developer SQL'],
    reg: ['Satis · Composer', 'Verdaccio · npm', 'GitLab Container Reg', 'Redgate · SQL Source Control'],
    tenant: 'Tenant build', tenant_sub1: 'on per-tenant VM', tenant_sub2: 'behind OpenVPN overlay',
    caption_bottom: 'No artifact reaches a tenant build without passing through an internal trust root.',
    cap3: 'Engagement time · by lane',
    lane: [
      ['Supply chain',        'Satis · Verdaccio · Redgate · registry creds'],
      ['IaC reconstruction',  'Semaphore API · idempotency · SSH-key hygiene'],
      ['Analytics stack',     'Metabase · Grafana provisioning'],
      ['Certificates & hardening', 'PKI · per-VM dev certs · trust chain'],
    ],
    note3: 'Lane percentages reflect the engineer\'s own time allocation across the engagement, not client-side performance measurements. Approximately one-third of the total effort sat in software supply-chain work — the same lane that CRA Article 13 and NIS2 Article 21(2) now make explicit obligations for European operators.',
  },
  de: {
    cap1: 'In Zahlen',
    note1: 'Alle vier Werte stammen aus den vier Repositories des Mandats oder aus dem bereitgestellten Infrastruktur-Inventar; keiner ist aus kunden-gemessenen Performance-Ergebnissen abgeleitet.',
    n1: ['~178', 'Commits über die vier Repositories', 'Orchestrierung · Reverse Proxy · PostgreSQL · Analytics'],
    n2: ['4',  'Artefakt-Kanäle über interne Registries', 'Composer · npm · SQL · Container'],
    n3: ['8',  'VM-Rollen im Semaphore-Katalog', 'Router · Orchestrator · Registry · Dev · Kunde · BI · Metriken · Pakete'],
    n4: ['4', 'Repositories end-to-end wiederbelebt', 'Codebasis 5+ Jahre alt · ursprünglich 2018–2019 erstellt'],
    cap2: 'Software-Lieferkette · interne Vertrauensanker',
    colA: 'ÖFFENTLICHE QUELLE', colB: 'INTERNER VERTRAUENSANKER', colC: 'TENANT-BUILD',
    pub: ['Packagist (öffentlich)', 'npm (öffentlich)', 'Öffentliche OCI-Registries', 'Ad-hoc-Entwickler-SQL'],
    reg: ['Satis · Composer', 'Verdaccio · npm', 'GitLab Container Reg', 'Redgate · SQL Source Control'],
    tenant: 'Tenant-Build', tenant_sub1: 'auf Per-Tenant-VM', tenant_sub2: 'hinter OpenVPN-Overlay',
    caption_bottom: 'Kein Artefakt erreicht einen Tenant-Build, ohne einen internen Vertrauensanker zu passieren.',
    cap3: 'Mandatszeit · nach Spur',
    lane: [
      ['Lieferkette',              'Satis · Verdaccio · Redgate · Registry-Credentials'],
      ['IaC-Rekonstruktion',       'Semaphore-API · Idempotenz · SSH-Key-Hygiene'],
      ['Analytics-Stack',          'Metabase- und Grafana-Provisionierung'],
      ['Zertifikate & Hardening',  'PKI · Per-VM-Entwickler-Zertifikate · Trust-Chain'],
    ],
    note3: 'Die Spuren-Prozente spiegeln die Zeit-Verteilung des Ingenieurs über das Mandat wider, nicht kunden-seitige Performance-Messungen. Etwa ein Drittel des Gesamtaufwands lag in der Software-Lieferketten-Arbeit — derselben Spur, die CRA Artikel 13 und NIS2 Artikel 21(2) nun zu expliziten Pflichten für europäische Betreiber machen.',
  },
  hr: {
    cap1: 'U brojkama',
    note1: 'Sva četiri broja izvučena su iz četiri repozitorija mandata ili iz inventara raspoređene infrastrukture; nijedan nije izveden iz klijentskih mjerenja performansi.',
    n1: ['~178', 'commitova kroz četiri repozitorija', 'orkestracija · reverse proxy · PostgreSQL · analitika'],
    n2: ['4',  'kanala artefakata kroz interne registre', 'Composer · npm · SQL · kontejner'],
    n3: ['8',  'VM uloga u Semaphore katalogu', 'usmjernik · orkestrator · registar · dev · klijent · BI · metrike · paketi'],
    n4: ['4', 'repozitorija oživljena end-to-end', 'kodna baza 5+ godina · izvorno autorstvo 2018.–2019.'],
    cap2: 'Softverski opskrbni lanac · interni korijeni povjerenja',
    colA: 'JAVNI IZVOR', colB: 'INTERNI KORIJEN POVJERENJA', colC: 'TENANT BUILD',
    pub: ['Packagist (javni)', 'npm (javni)', 'Javni OCI registri', 'Ad-hoc developer SQL'],
    reg: ['Satis · Composer', 'Verdaccio · npm', 'GitLab Container Reg', 'Redgate · SQL Source Control'],
    tenant: 'Tenant build', tenant_sub1: 'na per-tenant VM-u', tenant_sub2: 'iza OpenVPN sloja',
    caption_bottom: 'Nijedan artefakt ne dolazi do tenant builda bez prolaska kroz interni korijen povjerenja.',
    cap3: 'Vrijeme mandata · po području',
    lane: [
      ['Opskrbni lanac',          'Satis · Verdaccio · Redgate · vjerodajnice registra'],
      ['IaC rekonstrukcija',      'Semaphore API · idempotentnost · higijena SSH ključeva'],
      ['Analitički stack',        'Provizioniranje Metabasea i Grafane'],
      ['Certifikati i ojačavanje','PKI · po-VM developerski certifikati · lanac povjerenja'],
    ],
    note3: 'Postotci područja odražavaju inženjerovu vlastitu raspodjelu vremena kroz mandat, ne mjerenja performansi na strani klijenta. Otprilike trećina ukupnog truda bila je u radu na softverskom opskrbnom lancu — istom području koje CRA Članak 13 i NIS2 Članak 21(2) sada čine eksplicitnim obvezama za europske operatore.',
  },
}[locale];

const lanePcts = ['~30%', '~35%', '~20%', '~15%'];
const lanePx   = [114, 133, 76, 57]; // widths to match the percentages on the 380px scale
const laneYTextOffset = [56, 100, 144, 188];
const laneYSubOffset  = [72, 116, 160, 204];
const laneBarY        = [44, 88, 132, 176];
const laneOpacity     = [1, 0.85, 0.7, 0.55];
const laneValueX      = [420, 439, 382, 363];
const laneValueY      = [61, 105, 149, 193];
---

{/* === CHART 1 — Defensible numbers strip === */}
<figure class="my-10">
  <figcaption class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4 font-medium">{t.cap1}</figcaption>
  <div class="border border-ink-200 bg-white p-6 md:p-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {([t.n1, t.n2, t.n3, t.n4] as [string,string,string][]).map(([v, l, s]) => (
        <div>
          <div class="font-serif text-5xl text-accent-700 leading-none">{v}</div>
          <div class="mt-3 text-sm text-ink-700 leading-snug">{l}</div>
          <div class="mt-1 text-xs text-ink-500">{s}</div>
        </div>
      ))}
    </div>
  </div>
  <p class="mt-3 text-xs text-ink-500">{t.note1}</p>
</figure>

{/* === CHART 2 — Trust-root architecture === */}
<figure class="my-12">
  <figcaption class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4 font-medium">{t.cap2}</figcaption>
  <div class="border border-ink-200 bg-white p-6 md:p-8">
    <svg viewBox="0 0 720 320" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" role="img">
      <text x="100" y="28" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="#52525B" letter-spacing="1">{t.colA}</text>
      <text x="360" y="28" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="#1E3A8A" letter-spacing="1">{t.colB}</text>
      <text x="620" y="28" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="#52525B" letter-spacing="1">{t.colC}</text>

      <g font-family="Inter, sans-serif" font-size="12" fill="#52525B">
        {t.pub.map((label, i) => (
          <>
            <rect x="20" y={60 + i*55} width="160" height="36" fill="#FAFAFA" stroke="#A1A1AA" stroke-width="1" stroke-dasharray="4 2"/>
            <text x="100" y={83 + i*55} text-anchor="middle">{label}</text>
          </>
        ))}
      </g>

      <g font-family="Inter, sans-serif" font-size="12" fill="#FFFFFF" font-weight="600">
        {t.reg.map((label, i) => (
          <>
            <rect x="280" y={60 + i*55} width="160" height="36" fill="#1E3A8A"/>
            <text x="360" y={83 + i*55} text-anchor="middle">{label}</text>
          </>
        ))}
      </g>

      <rect x="540" y="60" width="160" height="201" fill="#FFFFFF" stroke="#1E3A8A" stroke-width="2"/>
      <text x="620" y="150" text-anchor="middle" font-family="Georgia, serif" font-size="16" font-weight="600" fill="#1E3A8A">{t.tenant}</text>
      <text x="620" y="170" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#52525B">{t.tenant_sub1}</text>
      <text x="620" y="186" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#52525B">{t.tenant_sub2}</text>

      <g stroke="#A1A1AA" stroke-width="1" stroke-dasharray="4 2" fill="none" marker-end="url(#arrowGrey)">
        <line x1="180" y1="78"  x2="280" y2="78"/>
        <line x1="180" y1="133" x2="280" y2="133"/>
        <line x1="180" y1="188" x2="280" y2="188"/>
        <line x1="180" y1="243" x2="280" y2="243"/>
      </g>
      <g stroke="#1E3A8A" stroke-width="1.5" fill="none" marker-end="url(#arrowBlue)">
        <line x1="440" y1="78"  x2="540" y2="78"/>
        <line x1="440" y1="133" x2="540" y2="133"/>
        <line x1="440" y1="188" x2="540" y2="188"/>
        <line x1="440" y1="243" x2="540" y2="243"/>
      </g>
      <defs>
        <marker id="arrowGrey" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto" markerUnits="strokeWidth">
          <path d="M0,0 L8,4 L0,8 Z" fill="#A1A1AA"/>
        </marker>
        <marker id="arrowBlue" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto" markerUnits="strokeWidth">
          <path d="M0,0 L8,4 L0,8 Z" fill="#1E3A8A"/>
        </marker>
      </defs>
      <text x="360" y="298" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#52525B">{t.caption_bottom}</text>
    </svg>
  </div>
</figure>

{/* === CHART 3 — Engagement-time allocation === */}
<figure class="my-12">
  <figcaption class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4 font-medium">{t.cap3}</figcaption>
  <div class="border border-ink-200 bg-white p-6 md:p-8">
    <svg viewBox="0 0 720 220" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" role="img">
      <g font-family="Inter, sans-serif" font-size="13" fill="#27272A">
        {t.lane.map(([name, sub], i) => (
          <>
            <text x="280" y={laneYTextOffset[i]} text-anchor="end" font-weight="600">{name}</text>
            <text x="280" y={laneYSubOffset[i]}  text-anchor="end" font-size="11" fill="#52525B">{sub}</text>
          </>
        ))}
      </g>
      {lanePcts.map((pct, i) => (
        <>
          <rect x="300" y={laneBarY[i]} width={lanePx[i]} height="22" fill="#1E3A8A" opacity={laneOpacity[i]} rx="2"/>
          <text x={laneValueX[i]} y={laneValueY[i]} font-family="Inter, sans-serif" font-size="12" font-weight="600" fill="#1E3A8A">{pct}</text>
        </>
      ))}
      <line x1="300" y1="40" x2="300" y2="206" stroke="#A1A1AA" stroke-width="1"/>
      <line x1="680" y1="40" x2="680" y2="206" stroke="#E4E4E7" stroke-width="1" stroke-dasharray="2 2"/>
      <text x="680" y="220" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="#A1A1AA">100%</text>
      <text x="300" y="220" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="#A1A1AA">0%</text>
    </svg>
  </div>
  <p class="mt-3 text-xs text-ink-500">{t.note3}</p>
</figure>
