---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import { getCollection } from 'astro:content';

// EN /work: only EN-locale studies (slugs without `de/` or `hr/` prefix).
// Without this filter the index renders 15 cards (5 × 3 locales) with
// mixed-language titles and summaries.
const studies = (await getCollection('case-studies', ({ slug, data }) =>
  !data.draft && !slug.startsWith('de/') && !slug.startsWith('hr/')
))
  .sort((a, b) => (b.data.publishedAt ?? '').localeCompare(a.data.publishedAt ?? ''));

const sectorsCovered = [...new Set(studies.map(s => s.data.sector))];
---
<BaseLayout
  title="Work — Thinking Machine"
  description="Anonymised case studies: cloud cost assessments, NFR compliance responses, AI integration. Two engagements published; others under reference embargo."
  pageType="CollectionPage"
>
  <section class="container-page pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden">
    <svg aria-hidden="true" class="absolute -top-20 -right-32 w-[420px] h-[420px] opacity-[0.04] pointer-events-none" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <rect x="20" y="20" width="160" height="160" stroke="#1E3A8A" stroke-width="1" fill="none"/>
      <rect x="50" y="50" width="100" height="100" stroke="#1E3A8A" stroke-width="1" fill="none"/>
      <rect x="80" y="80" width="40" height="40" stroke="#1E3A8A" stroke-width="1" fill="none"/>
    </svg>
    <div class="relative max-w-3xl">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-6 font-medium">Work</div>
      <h1 class="font-serif text-4xl md:text-6xl text-ink-900 leading-[1.05] tracking-tight">
        Anonymised engagements. Real numbers, no client names.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-ink-700 leading-relaxed">
        We publish case studies after engagements close and clients approve the anonymised text. We also publish methodology references — anonymised summaries of internal preparedness work. Others remain under reference embargo and are available on request.
      </p>
    </div>
  </section>

  {/* Recent engagement contexts — values come from the case-study `sector`
      field, which is written as an organisation descriptor, not a pure sector.
      The strip functions as a credibility marker, not a real filter. */}
  <section class="border-y border-ink-200 bg-ink-100/40">
    <div class="container-page py-5 flex flex-wrap items-center gap-x-6 gap-y-2">
      <span class="text-xs uppercase tracking-wider text-ink-500 font-medium">Recent engagement contexts</span>
      {sectorsCovered.map(s => <span class="text-sm text-ink-700">{s}</span>)}
    </div>
  </section>

  {/* "If you only read one" — an unranked grid of five case studies is a
      decision the buyer doesn't want to make. This callout names the most
      distinctive narrative as the recommended entry point. clinical-video
      is the strongest because it leads with a refusal (declining the
      AI Act's medical exemption for emotion recognition) — counterintuitive
      and memorable in a way the other four are not. */}
  <section class="container-page pt-12 md:pt-16">
    <div class="max-w-4xl bg-white border-l-4 border-l-accent-700 border border-ink-200 p-6 md:p-8 flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
      <div class="flex-shrink-0">
        <div class="text-xs uppercase tracking-[0.2em] text-accent-700 font-medium">If you only read one</div>
      </div>
      <div class="flex-1">
        <p class="text-ink-800 leading-relaxed">
          <a href="/work/clinical-video-consultation-mental-health" class="font-serif text-ink-900 no-underline hover:text-accent-800">Clinical-grade video consultation platform for an EU mental-health services provider</a> — the most distinctive engagement in the portfolio. Opens on a deliberate refusal: declining the AI Act's medical exemption for emotion recognition, anchored on a 1,000-study meta-analysis. Then the architecture and the 98% storage reduction.
        </p>
      </div>
      <div class="flex-shrink-0">
        <a href="/work/clinical-video-consultation-mental-health" class="inline-flex items-center gap-1 text-accent-700 no-underline text-sm whitespace-nowrap">Read it <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="container-page py-12 md:py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {studies.map(study => <CaseStudyCard study={study} />)}
    </div>
  </section>

  <section class="container-page pb-24">
    <div class="border-t border-ink-200 pt-12 max-w-prose">
      <p class="font-serif text-2xl md:text-3xl text-ink-900 leading-snug">
        Want to discuss work that's not on this page?
      </p>
      <p class="mt-4 text-ink-700 leading-relaxed">
        Some of our engagements remain confidential. We are happy to discuss them under NDA on a first call.
      </p>
      <div class="mt-8">
        <a href="/contact" class="btn-primary">Book a 30-minute intro</a>
      </div>
    </div>
  </section>
</BaseLayout>
