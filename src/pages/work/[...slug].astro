---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CRARegulatoryClock from '../../components/CRARegulatoryClock.astro';
import SupplyChainCaseStudyCharts from '../../components/SupplyChainCaseStudyCharts.astro';
import CaseStudyNumbersStrip from '../../components/CaseStudyNumbersStrip.astro';
import { getNumbersStrip } from '../../i18n/case-study-strips';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  // EN-only: filter out de/ and hr/ slugs (those are rendered by the locale
  // variants at src/pages/{de,hr}/work/[...slug].astro). Without this filter
  // the EN renderer generates duplicate paths like /work/de/foo that collide
  // with the canonical /de/work/foo.
  const studies = await getCollection('case-studies', ({ slug, data }) =>
    !data.draft && !slug.startsWith('de/') && !slug.startsWith('hr/')
  );
  return studies.map(study => ({
    params: { slug: study.slug },
    props: { study }
  }));
}

interface Props { study: CollectionEntry<'case-studies'>; }
const { study } = Astro.props;
const { Content } = await study.render();
const { title, sector, engagementType, year, region, summary, publishedAt } = study.data;

// Slug-conditional charts: keep the case-study .md files clean and inject
// data visualisations from the layout where the data has structure worth
// showing. Same set of components rendered on /de/work/<slug> and
// /hr/work/<slug>; EN was missing parity until this commit.
const isCRA = study.slug === 'cra-readiness-eu-manufacturer';
const isSupplyChain = study.slug === 'supply-chain-iac-saas-platform';
const numbersStrip = getNumbersStrip(study.slug, 'en');

// Case studies carry Article semantics for structured-data purposes —
// authored, dated, with a stable publication identity. Falls back to the
// engagement year if no publishedAt is set on the frontmatter.
const articleDate = publishedAt || `${year}-01-01`;
---
<BaseLayout
  title={`${title} — Thinking Machine`}
  description={summary}
  pageType="Article"
  datePublished={articleDate}
  ogImage={`/og/work-${study.slug}.png`}
>
  <article class="container-page py-16 md:py-24">
    <nav class="max-w-prose mx-auto mb-8 text-sm">
      <a href="/work" class="text-ink-500 hover:text-ink-900 no-underline">← All case studies</a>
    </nav>

    <header class="max-w-prose mx-auto mb-12">
      <div class="text-xs uppercase tracking-wider text-ink-500 mb-4">{engagementType}</div>
      <h1 class="font-serif text-3xl md:text-5xl text-ink-900 leading-[1.15]">
        {title}
      </h1>

      <dl class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-y-4 gap-x-8 text-sm border-t border-b border-ink-200 py-6">
        <div>
          <dt class="text-ink-500 text-xs uppercase tracking-wider">Engagement</dt>
          <dd class="mt-1 text-ink-800">{engagementType}</dd>
        </div>
        <div>
          <dt class="text-ink-500 text-xs uppercase tracking-wider">Sector</dt>
          <dd class="mt-1 text-ink-800">{sector}</dd>
        </div>
        <div>
          <dt class="text-ink-500 text-xs uppercase tracking-wider">Year</dt>
          <dd class="mt-1 text-ink-800">{year}</dd>
        </div>
        <div>
          <dt class="text-ink-500 text-xs uppercase tracking-wider">Region</dt>
          <dd class="mt-1 text-ink-800">{region}</dd>
        </div>
      </dl>
    </header>

    {numbersStrip && (
      <div class="max-w-4xl mx-auto mb-8">
        <CaseStudyNumbersStrip caption={numbersStrip.caption} note={numbersStrip.note} cells={numbersStrip.cells} />
      </div>
    )}

    {isCRA && (
      <div class="max-w-4xl mx-auto mb-12">
        <CRARegulatoryClock />
      </div>
    )}

    {isSupplyChain && (
      <div class="max-w-4xl mx-auto mb-12">
        <SupplyChainCaseStudyCharts locale="en" />
      </div>
    )}

    {study.data.quickRead ? (
      <>
        <section class="max-w-prose mx-auto mb-8">
          <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4 font-medium">Quick read</div>
          <div class="prose" set:html={study.data.quickRead.split('\n\n').map((para: string) => {
            const html = para.trim()
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')
              .replace(/\*\*([^\n]+?)\*\*/g, '<strong>$1</strong>')
              .replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
            return `<p>${html}</p>`;
          }).join('')} />
        </section>
        <section class="max-w-prose mx-auto">
          <details class="group">
            <summary class="cursor-pointer list-none border border-ink-200 bg-ink-50 px-6 py-4 inline-flex items-center gap-2 text-accent-700 font-medium text-sm hover:bg-ink-100 transition-colors">
              <span class="transition-transform duration-200 group-open:rotate-45 text-xl leading-none font-light" aria-hidden="true">+</span>
              <span class="group-open:hidden">Show the full case study</span>
              <span class="hidden group-open:inline">Hide full case study</span>
            </summary>
            <div class="prose mt-8">
              <Content />
            </div>
          </details>
        </section>
      </>
    ) : (
      <section class="prose mx-auto">
        <Content />
      </section>
    )}

    <hr class="section-divider mx-auto max-w-prose" />

    <section class="max-w-prose mx-auto">
      <p class="font-serif text-2xl text-ink-900 leading-snug">
        Working through something similar?
      </p>
      <p class="mt-4 text-ink-700">
        The first thirty minutes is on us — no pitch, no slides. We will tell you on the call
        whether we can help.
      </p>
      <div class="mt-6">
        <a href="/contact" class="btn-primary">Book a 30-minute intro</a>
      </div>
    </section>
  </article>
</BaseLayout>
