---
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import { getCollection } from 'astro:content';

const allStudies = await getCollection('case-studies', ({ data }) => !data.draft);
const featured = allStudies
  .filter(s => s.data.featured)
  .sort((a, b) => (b.data.publishedAt ?? '').localeCompare(a.data.publishedAt ?? ''));

const sectors = [
  { name: 'Healthcare IT', detail: 'HIS, lab automation, e-Health' },
  { name: 'Telecommunications', detail: 'CRM, billing, scale' },
  { name: 'Government R&D', detail: 'EU-funded consortia' },
  { name: 'Industrial IoT', detail: 'Multi-vendor, multi-site' },
  { name: 'Energy', detail: 'Operator-side procurement' },
  { name: 'Aviation', detail: 'Multi-tenant operations' },
];

const stats = [
  { num: '20+', label: 'Years of enterprise architecture' },
  { num: '6', label: 'Sectors of deep experience' },
  { num: '2–4', label: 'Weeks per decision (vs 4–6 months at a Big-4)' },
  { num: '1', label: 'Senior expert on the work, not a delivery team' },
];

const process = [
  { n: '01', t: 'Survey', d: 'We come in and listen — to the people who actually know. Most of what matters is not written down. We surface it.' },
  { n: '02', t: 'Map', d: 'We draw the current situation: data flows, decision rights, dependencies, gaps. Everyone sees the same picture.' },
  { n: '03', t: 'Think', d: 'The hard part. We anchor on published frameworks and our cross-sector pattern library. We look for the analogy that has already been solved.' },
  { n: '04', t: 'Deliver', d: 'A document your board reads in fifteen minutes. Backed by a model that survives a hostile read. With every claim cited.' },
];

const methodologies = [
  { name: 'Five-pass verbatim verification', desc: 'Every load-bearing claim cited to source.' },
  { name: 'Position of Record', desc: 'Authoritative voice with traceable evidence chain.' },
  { name: 'Propagation matrix', desc: 'Cross-document audit trail. Nothing falls through.' },
  { name: 'Four-category cost taxonomy', desc: 'Fixed overhead · Competence · Variable · Per-server.' },
  { name: 'Triangulated baseline', desc: 'When invoices are unavailable, anchor on public pricing × partner-margin band.' },
  { name: 'L / I / B classification', desc: 'Findings tagged Legally Required · Implicit Means · Best Practice.' },
];

const comparison = [
  { who: 'Big-4 / strategy house', they: 'Branded report, multi-tier delivery team, 4–6-month engagement.', us: 'One senior expert. 2–4 weeks. Same depth, sharper.' },
  { who: 'Domain freelancer', they: 'Deep in one vertical. Project-by-project — no shared methodology library.', us: 'Twenty years across six sectors. Audit-grade methodology.' },
  { who: 'System integrator', they: 'Will gladly recommend the implementation work they’re selling.', us: 'No implementation conflict. We will not build what we recommend.' },
  { who: 'Internal team', they: 'Free, contextual. But politically constrained, no external calibration.', us: 'External read. Permission to say what is politically inconvenient.' },
];

const faqs = [
  { q: "How long is a typical engagement?", a: "Discovery Sprints run 1–2 weeks. Rapid PoCs run 2–4 weeks. Fractional CTO is monthly retainer. We never sell engagements that expand themselves — every shape has a fixed scope and end date declared up front." },
  { q: "How do you price?", a: "Fixed fee, quoted on the first call before any commitment. We do not bill hourly. There are no expansion clauses. The introductory thirty-minute call is free regardless of outcome." },
  { q: "Will you sign an NDA before the first call?", a: "Yes. Send it ahead of time and we will sign before the call. Many existing engagements remain under reference embargo at the client's request." },
  { q: "Do you also implement what you recommend?", a: "No. Separation of advisory and implementation is structural, not stylistic. If your engagement uncovers work that needs an implementation team, we will help you scope it but not deliver it." },
  { q: "Can you work with clients outside the European Union?", a: "Yes. Our base is Zagreb, Croatia, and most engagements are EU-based, but we have worked with clients in Norway, the UK, Germany, and beyond. Remote-first; we travel for kickoff and final-readout meetings when warranted." },
  { q: "What sectors do you specialise in?", a: "Healthcare IT, telecommunications, government R&D, industrial IoT, energy, and aviation. The cross-domain pattern library is itself the value: your problem has often already been solved in an adjacent sector." },
  { q: "How quickly can you start?", a: "We take one to two new engagements per quarter. Lead time is usually two to six weeks depending on existing commitments." },
  { q: "What if you decide we're not the right fit?", a: "We will say so on the first call and, where possible, point you to someone better suited. We do not take work where AI, cloud, or compliance is not actually the right answer." }
];

const faqJsonLd = {
  "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: faqs.map(({ q, a }) => ({ "@type": "Question", name: q, acceptedAnswer: { "@type": "Answer", text: a } }))
};
---
<BaseLayout
  title="Thinking Machine — Delegate the hard thinking"
  description="Hand us the hard architectural, cloud-cost, or compliance question. We survey, map, think, and deliver a board-ready answer. Fixed-scope, decision-grade, 2–4 weeks. Twenty years across six sectors."
>
  {/* HERO */}
  <section class="container-page pt-20 pb-20 md:pt-32 md:pb-28 relative overflow-hidden">
    <svg aria-hidden="true" class="absolute -top-24 -right-24 w-[480px] h-[480px] opacity-[0.04] pointer-events-none" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <circle cx="100" cy="100" r="98" stroke="#1E3A8A" stroke-width="1" fill="none"/>
      <circle cx="100" cy="100" r="70" stroke="#1E3A8A" stroke-width="1" fill="none"/>
      <circle cx="100" cy="100" r="42" stroke="#1E3A8A" stroke-width="1" fill="none"/>
    </svg>
    <div class="relative">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-6 font-medium anim-fade-up">
        Thinking Machine d.o.o. · Boutique engineering advisory
      </div>
      <h1 class="font-serif text-4xl md:text-6xl lg:text-7xl text-ink-900 leading-[1.05] tracking-tight max-w-5xl anim-fade-up anim-delay-100">
        Hand us the hard question. We come back with a defensible answer.
      </h1>
      <p class="mt-8 text-xl md:text-2xl text-ink-700 font-serif italic max-w-3xl leading-snug anim-fade-up anim-delay-200">
        Delegate the thinking. We come in, listen carefully, map what's actually there, do the analysis, and deliver the document your board can read in fifteen minutes.
      </p>
      <div class="mt-10 flex flex-wrap gap-4 anim-fade-up anim-delay-300">
        <a href="/contact" class="btn-primary">Book a 30-minute intro</a>
        <a href="#how" class="btn-secondary">See how we work →</a>
      </div>
    </div>
  </section>

  {/* SECTOR STRIP */}
  <section class="border-y border-ink-200 bg-ink-100/40">
    <div class="container-page py-6 flex flex-wrap items-center gap-x-8 gap-y-3">
      <span class="text-xs uppercase tracking-wider text-ink-500 font-medium">Twenty-plus years across</span>
      {sectors.map(s => <span class="text-sm text-ink-700">{s.name}</span>)}
    </div>
  </section>

  {/* STATS STRIP */}
  <section class="container-page py-16 md:py-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {stats.map(s => (
        <div class="border-t-2 border-accent-700 pt-5">
          <div class="stat-numeral">{s.num}</div>
          <div class="mt-3 text-sm text-ink-700 leading-snug">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  {/* PROCESS — the survey/map/think/deliver narrative */}
  <section id="how" class="bg-ink-100/50 border-y border-ink-200">
    <div class="container-page py-20 md:py-24">
      <div class="max-w-2xl mb-14">
        <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">How we work</div>
        <h2 class="font-serif text-3xl md:text-5xl text-ink-900 leading-[1.1]">Survey. Map. Think. Deliver.</h2>
        <p class="mt-5 text-ink-700 text-lg leading-relaxed">
          The hard part is not the answer — it is finding out what is actually true inside your organisation, then thinking carefully about what to do. We do both.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-4">
        {process.map(p => (
          <div class="bg-white border border-ink-200 border-t-4 border-t-accent-700 p-7 card-lift">
            <div class="font-serif text-3xl text-accent-700 font-semibold mb-3">{p.n}</div>
            <h3 class="font-serif text-xl text-ink-900 mb-3 leading-tight">{p.t}</h3>
            <p class="text-ink-700 text-sm leading-relaxed">{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* WHAT WE DO — three lanes */}
  <section id="what-we-do" class="container-page py-20 md:py-24">
    <div class="max-w-2xl mb-14">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">What we do</div>
      <h2 class="font-serif text-3xl md:text-5xl text-ink-900 leading-[1.1]">Three lanes. Same engagement model.</h2>
    </div>
    <div class="grid gap-px bg-ink-200 border border-ink-200 md:grid-cols-3">
      <article class="bg-white p-8 md:p-10 hover:bg-ink-50 transition-colors group">
        <div class="text-xs uppercase tracking-wider text-accent-700 mb-3 font-medium">01 · Cloud</div>
        <h3 class="font-serif text-2xl text-ink-900 mb-4 leading-tight">Cloud cost & FinOps strategy</h3>
        <p class="text-ink-700 leading-relaxed">
          Board-grade cost assessments anchored on published frameworks. Triangulated baselines, multi-scenario reserved-instance modelling, vendor-side pricing playbooks. The document the decision-maker reads.
        </p>
        <a href="/services#cloud-cost" class="inline-flex items-center gap-1 mt-5 text-sm text-accent-700 no-underline group/link">Read more on cloud cost <span class="transition-transform group-hover/link:translate-x-1">→</span></a>
      </article>
      <article class="bg-white p-8 md:p-10 hover:bg-ink-50 transition-colors group">
        <div class="text-xs uppercase tracking-wider text-accent-700 mb-3 font-medium">02 · Cyber</div>
        <h3 class="font-serif text-2xl text-ink-900 mb-4 leading-tight">Cyber resilience, NIS2 & CRA</h3>
        <p class="text-ink-700 leading-relaxed">
          Cyber Resilience Act readiness. NIS2 transposition. Azure-native security architecture. Structured NFR responses for procurement and pre-contract due diligence. Audit-defensible positions, not opinions.
        </p>
        <a href="/services#cyber" class="inline-flex items-center gap-1 mt-5 text-sm text-accent-700 no-underline group/link">Read more on cyber resilience <span class="transition-transform group-hover/link:translate-x-1">→</span></a>
      </article>
      <article class="bg-white p-8 md:p-10 hover:bg-ink-50 transition-colors group">
        <div class="text-xs uppercase tracking-wider text-accent-700 mb-3 font-medium">03 · AI</div>
        <h3 class="font-serif text-2xl text-ink-900 mb-4 leading-tight">AI integration for established systems</h3>
        <p class="text-ink-700 leading-relaxed">
          MCP control layers. RAG over enterprise knowledge. On-prem LLM infra for data-residency-sensitive sectors. We connect modern frontier models to the systems you already have — no all-in transformation pitch.
        </p>
        <a href="/services#ai" class="inline-flex items-center gap-1 mt-5 text-sm text-accent-700 no-underline group/link">Read more on AI integration <span class="transition-transform group-hover/link:translate-x-1">→</span></a>
      </article>
    </div>
  </section>

  {/* WHAT WE BRING — methodology library */}
  <section class="bg-ink-100/40 border-y border-ink-200">
    <div class="container-page py-20 md:py-24">
      <div class="grid md:grid-cols-3 gap-12 mb-12">
        <div>
          <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">What we bring</div>
          <h2 class="font-serif text-3xl md:text-4xl text-ink-900 leading-tight">A small library of named techniques.</h2>
          <p class="mt-5 text-ink-700 leading-relaxed">
            We do not invent methodology on your dime. Each engagement starts from a small library of techniques we have refined across regulatory, cost, and architecture work — and are explicit about citing.
          </p>
        </div>
        <div class="md:col-span-2 grid sm:grid-cols-2 gap-3">
          {methodologies.map(m => (
            <div class="bg-white border-l-2 border-accent-700 px-5 py-4">
              <div class="font-serif text-base text-ink-900 mb-1">{m.name}</div>
              <div class="text-sm text-ink-700">{m.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* CROSS-SECTOR LIBRARY — the polymath signal */}
  <section class="container-page py-20 md:py-24">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">Cross-sector library</div>
        <h2 class="font-serif text-3xl md:text-4xl text-ink-900 leading-tight">Your problem has often already been solved next door.</h2>
        <p class="mt-5 text-ink-700 leading-relaxed">
          Most consultants spend a career in one sector. We have shipped systems in six. The integration patterns from healthcare lab automation, the procurement-NFR rigor from energy, the multi-tenant runtime work from industrial IoT — they translate.
        </p>
        <p class="mt-4 text-ink-700 leading-relaxed">
          When we say "we have seen this before", we usually have — just somewhere unexpected.
        </p>
      </div>
      <div class="relative aspect-square max-w-md mx-auto">
        <svg viewBox="0 0 400 400" class="w-full h-full" xmlns="http://www.w3.org/2000/svg" aria-label="Sectors cross-pollination diagram">
          <circle cx="200" cy="200" r="60" fill="#1E3A8A"/>
          <text x="200" y="195" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="600" fill="white">Cross-</text>
          <text x="200" y="212" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="600" fill="white">domain</text>
          {sectors.map((s, i) => {
            const angle = (i / sectors.length) * Math.PI * 2 - Math.PI / 2;
            const x = 200 + Math.cos(angle) * 150;
            const y = 200 + Math.sin(angle) * 150;
            const tx = 200 + Math.cos(angle) * 175;
            const ty = 200 + Math.sin(angle) * 175;
            const anchor = Math.cos(angle) > 0.3 ? 'start' : Math.cos(angle) < -0.3 ? 'end' : 'middle';
            return (
              <>
                <line x1="200" y1="200" x2={x} y2={y} stroke="#1E3A8A" stroke-width="1" opacity="0.25"/>
                <circle cx={x} cy={y} r="8" fill="#1E3A8A" opacity="0.2"/>
                <circle cx={x} cy={y} r="4" fill="#1E3A8A"/>
                <text x={tx} y={ty + 4} text-anchor={anchor} font-family="Inter, sans-serif" font-size="12" fill="#27272A">{s.name}</text>
              </>
            );
          })}
        </svg>
      </div>
    </div>
  </section>

  {/* WHY US — comparison table */}
  <section class="bg-ink-100/50 border-y border-ink-200">
    <div class="container-page py-20 md:py-24">
      <div class="max-w-2xl mb-12">
        <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">Why us</div>
        <h2 class="font-serif text-3xl md:text-5xl text-ink-900 leading-[1.1]">Honest comparison.</h2>
        <p class="mt-5 text-ink-700 text-lg leading-relaxed">
          We know the alternatives. Here is where we slot in — and where we do not.
        </p>
      </div>
      <div class="overflow-hidden border border-ink-200 bg-white">
        <table class="w-full text-sm md:text-base">
          <thead class="bg-ink-100 text-left">
            <tr>
              <th class="font-medium text-ink-700 px-5 md:px-6 py-4 text-xs uppercase tracking-wider">If you go to</th>
              <th class="font-medium text-ink-700 px-5 md:px-6 py-4 text-xs uppercase tracking-wider">You typically get</th>
              <th class="font-medium text-accent-700 px-5 md:px-6 py-4 text-xs uppercase tracking-wider">With us</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ink-200">
            {comparison.map(c => (
              <tr class="hover:bg-ink-50 transition-colors">
                <td class="px-5 md:px-6 py-5 align-top font-medium text-ink-900 whitespace-nowrap">{c.who}</td>
                <td class="px-5 md:px-6 py-5 align-top text-ink-700">{c.they}</td>
                <td class="px-5 md:px-6 py-5 align-top text-ink-900 font-medium">{c.us}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {/* DELIVERABLES BENTO */}
  <section class="container-page py-20 md:py-24">
    <div class="max-w-2xl mb-12">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">Deliverables</div>
      <h2 class="font-serif text-3xl md:text-5xl text-ink-900 leading-[1.1]">What you actually get.</h2>
      <p class="mt-5 text-ink-700 text-lg leading-relaxed">
        Tangible artifacts you keep. No deck-only deliverables, no executive summary with nothing underneath.
      </p>
    </div>
    <div class="grid gap-4 grid-cols-1 md:grid-cols-3 md:grid-rows-2 md:auto-rows-fr">
      <div class="md:col-span-2 md:row-span-2 bg-accent-700 text-white p-8 md:p-10 flex flex-col justify-between min-h-[320px] card-lift">
        <div>
          <div class="text-xs uppercase tracking-[0.2em] opacity-70 mb-3 font-medium">Primary deliverable</div>
          <h3 class="font-serif text-3xl md:text-4xl leading-tight">Decision-grade report</h3>
        </div>
        <p class="opacity-90 leading-relaxed mt-6 text-lg">
          A document the board reads in fifteen minutes — anchored on published frameworks, with explicit scope, methodology, evidence trails, and a recommendation that survives a hostile read.
        </p>
      </div>
      <div class="bg-white border border-ink-200 p-7 card-lift">
        <div class="text-xs uppercase tracking-wider text-accent-700 mb-2 font-medium">Working artifact</div>
        <h3 class="font-serif text-xl text-ink-900 mb-3 leading-tight">Cost model spreadsheet</h3>
        <p class="text-ink-700 text-sm leading-relaxed">Multi-sheet, scenario-modelled, you populate inputs and the answer changes.</p>
      </div>
      <div class="bg-white border border-ink-200 p-7 card-lift">
        <div class="text-xs uppercase tracking-wider text-accent-700 mb-2 font-medium">NFR / CRA toolkit</div>
        <h3 class="font-serif text-xl text-ink-900 mb-3 leading-tight">Compliance register + evidence log</h3>
        <p class="text-ink-700 text-sm leading-relaxed">One row per requirement. Status, justification, evidence, cost-impact, action.</p>
      </div>
      <div class="bg-white border border-ink-200 p-7 card-lift">
        <div class="text-xs uppercase tracking-wider text-accent-700 mb-2 font-medium">For AI work</div>
        <h3 class="font-serif text-xl text-ink-900 mb-3 leading-tight">Working PoC + go/no-go memo</h3>
        <p class="text-ink-700 text-sm leading-relaxed">A demonstration in code, not a slide. Plus an honest evaluation of whether to proceed.</p>
      </div>
      <div class="bg-white border border-ink-200 p-7 card-lift">
        <div class="text-xs uppercase tracking-wider text-accent-700 mb-2 font-medium">Always</div>
        <h3 class="font-serif text-xl text-ink-900 mb-3 leading-tight">Out-of-scope declaration</h3>
        <p class="text-ink-700 text-sm leading-relaxed">Up front, in writing — what we deliver, and what we deliberately do not.</p>
      </div>
    </div>
  </section>

  {/* ENGAGEMENT SHAPES — Discovery / PoC / Fractional CTO */}
  <section class="bg-ink-100/40 border-y border-ink-200">
    <div class="container-page py-16 md:py-20">
      <div class="max-w-2xl mb-12">
        <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">Engagement shapes</div>
        <h2 class="font-serif text-3xl md:text-4xl text-ink-900 leading-[1.15]">Three shapes you can actually approve.</h2>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        <div class="bg-white border border-ink-200 border-l-4 border-l-accent-700 p-7 card-lift">
          <div class="text-xs uppercase tracking-wider text-ink-500 mb-2">Stage 1</div>
          <p class="font-serif text-2xl text-ink-900 mb-2">Discovery Sprint</p>
          <p class="text-sm text-ink-500 mb-4 font-medium">1–2 weeks · fixed fee</p>
          <p class="text-ink-700">Scoped problem, structured deliverable, decision-ready output.</p>
        </div>
        <div class="bg-white border border-ink-200 border-l-4 border-l-accent-700 p-7 card-lift">
          <div class="text-xs uppercase tracking-wider text-ink-500 mb-2">Stage 2</div>
          <p class="font-serif text-2xl text-ink-900 mb-2">Rapid PoC</p>
          <p class="text-sm text-ink-500 mb-4 font-medium">2–4 weeks · fixed fee</p>
          <p class="text-ink-700">Working demonstration plus an evidence-based go/no-go.</p>
        </div>
        <div class="bg-white border border-ink-200 border-l-4 border-l-accent-700 p-7 card-lift">
          <div class="text-xs uppercase tracking-wider text-ink-500 mb-2">Stage 3</div>
          <p class="font-serif text-2xl text-ink-900 mb-2">Fractional CTO</p>
          <p class="text-sm text-ink-500 mb-4 font-medium">Monthly retainer</p>
          <p class="text-ink-700">A senior architect on call. Sounding-board for the in-house team, RFP due diligence, second-opinion reviews. For when the team is strong but missing one specific area of depth.</p>
        </div>
      </div>
      <p class="mt-10 max-w-prose text-ink-700">
        We take <strong class="text-ink-900">one to two new engagements per quarter</strong>. The first thirty minutes is always free — no pitch, no slide deck.
      </p>
    </div>
  </section>

  {/* RECENT WORK */}
  <section class="container-page py-20 md:py-24">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-12">
      <div>
        <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">Recent work</div>
        <h2 class="font-serif text-3xl md:text-5xl text-ink-900 leading-[1.1]">Anonymised case studies.</h2>
      </div>
      <a href="/work" class="text-sm text-accent-700 no-underline whitespace-nowrap">See all engagements →</a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {featured.map(study => <CaseStudyCard study={study} />)}
    </div>
  </section>

  {/* PULL QUOTE */}
  <section class="bg-accent-700 text-white">
    <div class="container-page py-20 md:py-28 max-w-prose">
      <div class="font-serif text-2xl md:text-4xl leading-[1.25] tracking-tight">
        Most consulting engagements are designed to expand. Discovery becomes Phase 1; Phase 1 becomes Phase 2; the meter runs. We do not work that way.
      </div>
      <div class="mt-6 text-sm uppercase tracking-wider opacity-70">Why fixed-scope · <a href="/about" class="no-underline text-white opacity-100 underline-offset-4 underline">Read the full About →</a></div>
    </div>
  </section>

  {/* FAQ */}
  <section class="container-page py-20 md:py-24">
    <div class="max-w-2xl mb-12">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">Frequently asked</div>
      <h2 class="font-serif text-3xl md:text-5xl text-ink-900 leading-[1.1]">Questions buyers usually ask first.</h2>
    </div>
    <div class="max-w-3xl divide-y divide-ink-200 border-t border-b border-ink-200">
      {faqs.map(item => (
        <details class="group py-6">
          <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
            <h3 class="font-serif text-xl md:text-2xl text-ink-900 leading-snug pr-4">{item.q}</h3>
            <span class="flex-shrink-0 mt-1 text-accent-700 transition-transform duration-200 group-open:rotate-45 text-2xl leading-none font-light" aria-hidden="true">+</span>
          </summary>
          <div class="mt-4 text-ink-700 leading-relaxed max-w-prose">{item.a}</div>
        </details>
      ))}
