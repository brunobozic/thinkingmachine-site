---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CRARegulatoryClock from '../../../components/CRARegulatoryClock.astro';
import SupplyChainCaseStudyCharts from '../../../components/SupplyChainCaseStudyCharts.astro';
import CaseStudyNumbersStrip from '../../../components/CaseStudyNumbersStrip.astro';
import { getNumbersStrip } from '../../../i18n/case-study-strips';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies', ({ slug, data }) => slug.startsWith('de/') && !data.draft);
  return studies.map(study => ({
    // Strip the de/ prefix from the URL — file slug 'de/foo' renders at /de/work/foo
    params: { slug: study.slug.replace(/^de\//, '') },
    props: { study }
  }));
}

interface Props { study: CollectionEntry<'case-studies'>; }
const { study } = Astro.props;
const { Content } = await study.render();
const { title, sector, engagementType, year, region, summary } = study.data;

const bareSlug = study.slug.replace(/^de\//, '');
const isCRA = bareSlug === 'cra-readiness-eu-manufacturer';
const isSupplyChain = bareSlug === 'supply-chain-iac-saas-platform';
const numbersStrip = getNumbersStrip(bareSlug, 'de');
---
<BaseLayout
  title={`${title} — Thinking Machine`}
  description={summary}
>
  <article class="container-page py-16 md:py-24">
    <nav class="max-w-prose mx-auto mb-8 text-sm">
      <a href="/de/work" class="text-ink-500 hover:text-ink-900 no-underline">← Alle Fallstudien</a>
    </nav>

    <header class="max-w-prose mx-auto mb-12">
      <div class="text-xs uppercase tracking-wider text-ink-500 mb-4">{engagementType}</div>
      <h1 class="font-serif text-3xl md:text-5xl text-ink-900 leading-[1.15]">
        {title}
      </h1>

      <dl class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-y-4 gap-x-8 text-sm border-t border-b border-ink-200 py-6">
        <div><dt class="text-ink-500 text-xs uppercase tracking-wider">Mandat</dt><dd class="mt-1 text-ink-800">{engagementType}</dd></div>
        <div><dt class="text-ink-500 text-xs uppercase tracking-wider">Sektor</dt><dd class="mt-1 text-ink-800">{sector}</dd></div>
        <div><dt class="text-ink-500 text-xs uppercase tracking-wider">Jahr</dt><dd class="mt-1 text-ink-800">{year}</dd></div>
        <div><dt class="text-ink-500 text-xs uppercase tracking-wider">Region</dt><dd class="mt-1 text-ink-800">{region}</dd></div>
      </dl>
    </header>

    {numbersStrip && (
      <div class="max-w-4xl mx-auto mb-8">
        <CaseStudyNumbersStrip caption={numbersStrip.caption} note={numbersStrip.note} cells={numbersStrip.cells} />
      </div>
    )}

    {isCRA && (
      <div class="max-w-4xl mx-auto mb-12">
        <CRARegulatoryClock />
      </div>
    )}

    {isSupplyChain && (
      <div class="max-w-4xl mx-auto mb-12">
        <SupplyChainCaseStudyCharts locale="de" />
      </div>
    )}

    {study.data.quickRead ? (
      <>
        <section class="max-w-prose mx-auto mb-8">
          <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4 font-medium">Kurzfassung</div>
          <div class="prose" set:html={study.data.quickRead.split('\n\n').map((p: string) => `<p>${p.trim()}</p>`).join('')} />
        </section>
        <section class="max-w-prose mx-auto">
          <details class="group">
            <summary class="cursor-pointer list-none border border-ink-200 bg-ink-50 px-6 py-4 inline-flex items-center gap-2 text-accent-700 font-medium text-sm hover:bg-ink-100 transition-colors">
              <span class="transition-transform duration-200 group-open:rotate-45 text-xl leading-none font-light" aria-hidden="true">+</span>
              <span class="group-open:hidden">Vollständige Fallstudie anzeigen</span>
              <span class="hidden group-open:inline">Vollständige Fallstudie ausblenden</span>
            </summary>
            <div class="prose mt-8">
              <Content />
            </div>
          </details>
        </section>
      </>
    ) : (
      <section class="prose mx-auto">
        <Content />
      </section>
    )}

    <hr class="section-divider mx-auto max-w-prose" />

    <section class="max-w-prose mx-auto">
      <p class="font-serif text-2xl text-ink-900 leading-snug">Etwas Ähnliches in Arbeit?</p>
      <p class="mt-4 text-ink-700">Die ersten dreißig Minuten gehen auf uns — kein Pitch, keine Folien. Wir sagen Ihnen im Gespräch, ob wir helfen können.</p>
      <div class="mt-6"><a href="/de/contact" class="btn-primary">30-minütiges Erstgespräch buchen</a></div>
    </section>
  </article>
</BaseLayout>
