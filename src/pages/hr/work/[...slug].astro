---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CRARegulatoryClock from '../../../components/CRARegulatoryClock.astro';
import SupplyChainCaseStudyCharts from '../../../components/SupplyChainCaseStudyCharts.astro';
import CaseStudyNumbersStrip from '../../../components/CaseStudyNumbersStrip.astro';
import { getNumbersStrip } from '../../../i18n/case-study-strips';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies', ({ slug, data }) => slug.startsWith('hr/') && !data.draft);
  return studies.map(study => ({
    params: { slug: study.slug.replace(/^hr\//, '') },
    props: { study }
  }));
}

interface Props { study: CollectionEntry<'case-studies'>; }
const { study } = Astro.props;
const { Content } = await study.render();
const { title, sector, engagementType, year, region, summary } = study.data;

const bareSlug = study.slug.replace(/^hr\//, '');
const isCRA = bareSlug === 'cra-readiness-eu-manufacturer';
const isSupplyChain = bareSlug === 'supply-chain-iac-saas-platform';
const numbersStrip = getNumbersStrip(bareSlug, 'hr');
---
<BaseLayout
  title={`${title} — Thinking Machine`}
  description={summary}
>
  <article class="container-page py-16 md:py-24">
    <nav class="max-w-prose mx-auto mb-8 text-sm">
      <a href="/hr/work" class="text-ink-500 hover:text-ink-900 no-underline">← Sve studije slučaja</a>
    </nav>

    <header class="max-w-prose mx-auto mb-12">
      <div class="text-xs uppercase tracking-wider text-ink-500 mb-4">{engagementType}</div>
      <h1 class="font-serif text-3xl md:text-5xl text-ink-900 leading-[1.15]">
        {title}
      </h1>

      <dl class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-y-4 gap-x-8 text-sm border-t border-b border-ink-200 py-6">
        <div><dt class="text-ink-500 text-xs uppercase tracking-wider">Mandat</dt><dd class="mt-1 text-ink-800">{engagementType}</dd></div>
        <div><dt class="text-ink-500 text-xs uppercase tracking-wider">Sektor</dt><dd class="mt-1 text-ink-800">{sector}</dd></div>
        <div><dt class="text-ink-500 text-xs uppercase tracking-wider">Godina</dt><dd class="mt-1 text-ink-800">{year}</dd></div>
        <div><dt class="text-ink-500 text-xs uppercase tracking-wider">Regija</dt><dd class="mt-1 text-ink-800">{region}</dd></div>
      </dl>
    </header>

    {numbersStrip && (
      <div class="max-w-4xl mx-auto mb-8">
        <CaseStudyNumbersStrip caption={numbersStrip.caption} note={numbersStrip.note} cells={numbersStrip.cells} />
      </div>
    )}

    {isCRA && (
      <div class="max-w-4xl mx-auto mb-12">
        <CRARegulatoryClock />
      </div>
    )}

    {isSupplyChain && (
      <div class="max-w-4xl mx-auto mb-12">
        <SupplyChainCaseStudyCharts locale="hr" />
      </div>
    )}

    <section class="prose mx-auto">
      <Content />
    </section>

    <hr class="section-divider mx-auto max-w-prose" />

    <section class="max-w-prose mx-auto">
      <p class="font-serif text-2xl text-ink-900 leading-snug">Imate nešto slično u tijeku?</p>
      <p class="mt-4 text-ink-700">Prvih trideset minuta ide na nas — bez pitcha, bez slajdova. U razgovoru ćemo vam reći možemo li pomoći.</p>
      <div class="mt-6"><a href="/hr/contact" class="btn-primary">Rezervirajte 30-minutni razgovor</a></div>
    </section>
  </article>
</BaseLayout>
