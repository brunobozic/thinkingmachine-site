---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CaseStudyCard from '../../../components/CaseStudyCard.astro';
import { getCollection } from 'astro:content';

const studies = (await getCollection('case-studies', ({ slug, data }) => slug.startsWith('hr/') && !data.draft))
  .sort((a, b) => (b.data.publishedAt ?? '').localeCompare(a.data.publishedAt ?? ''));

const sectorsCovered = [...new Set(studies.map(s => s.data.sector))];
---
<BaseLayout
  title="Rad — Thinking Machine"
  description="Anonimizirane studije slučaja i metodološke reference: cloud troškovi, NFR sukladnost, CRA spremnost, kontrole softverskog opskrbnog lanca. Četiri objavljene; ostale pod embargom reference."
  pageType="CollectionPage"
>
  <section class="container-page pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden">
    <svg aria-hidden="true" class="absolute -top-20 -right-32 w-[420px] h-[420px] opacity-[0.04] pointer-events-none" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <rect x="20" y="20" width="160" height="160" stroke="#1E3A8A" stroke-width="1" fill="none"/>
      <rect x="50" y="50" width="100" height="100" stroke="#1E3A8A" stroke-width="1" fill="none"/>
      <rect x="80" y="80" width="40" height="40" stroke="#1E3A8A" stroke-width="1" fill="none"/>
    </svg>
    <div class="relative max-w-3xl">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-6 font-medium">Rad</div>
      <h1 class="font-serif text-4xl md:text-6xl text-ink-900 leading-[1.05] tracking-tight">
        Anonimizirani mandati. Prave brojke, bez imena klijenata.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-ink-700 leading-relaxed">
        Studije slučaja objavljujemo nakon zatvaranja mandata i nakon što klijent odobri anonimizirani tekst. Također objavljujemo metodološke reference — anonimizirane sažetke interne pripremne radne. Ostale ostaju pod embargom reference i dostupne su na zahtjev.
      </p>
    </div>
  </section>

  <section class="border-y border-ink-200 bg-ink-100/40">
    <div class="container-page py-5 flex flex-wrap items-center gap-x-6 gap-y-2">
      <span class="text-xs uppercase tracking-wider text-ink-500 font-medium">Nedavni konteksti mandata</span>
      {sectorsCovered.map(s => <span class="text-sm text-ink-700">{s}</span>)}
    </div>
  </section>

  {/* "Ako pročitate samo jednu" — preporuka najmarkantnije studije slučaja. */}
  <section class="container-page pt-12 md:pt-16">
    <div class="max-w-4xl bg-white border-l-4 border-l-accent-700 border border-ink-200 p-6 md:p-8 flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
      <div class="flex-shrink-0">
        <div class="text-xs uppercase tracking-[0.2em] text-accent-700 font-medium">Ako pročitate samo jednu</div>
      </div>
      <div class="flex-1">
        <p class="text-ink-800 leading-relaxed">
          <a href="/hr/work/clinical-video-consultation-mental-health" class="font-serif text-ink-900 no-underline hover:text-accent-800">Klinička platforma za video-konzultacije za EU pružatelja usluga mentalnog zdravlja</a> — najmarkantniji mandat u portfelju. Otvara se odbijanjem: ne koristiti medicinsku iznimku iz AI Acta za prepoznavanje emocija, oslanjajući se na meta-analizu nad više od 1 000 studija. Zatim arhitektura i redukcija pohrane od 98 %.
        </p>
      </div>
      <div class="flex-shrink-0">
        <a href="/hr/work/clinical-video-consultation-mental-health" class="inline-flex items-center gap-1 text-accent-700 no-underline text-sm whitespace-nowrap">Pročitaj <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="container-page py-12 md:py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {studies.map(study => <CaseStudyCard study={study} locale="hr" />)}
    </div>
  </section>

  <section class="container-page pb-24">
    <div class="border-t border-ink-200 pt-12 max-w-prose">
      <p class="font-serif text-2xl md:text-3xl text-ink-900 leading-snug">Imate nešto slično pred sobom?</p>
      <p class="mt-4 text-ink-700">Prvih trideset minuta ide na nas — bez pitcha, bez slajdova. U razgovoru ćemo vam reći možemo li pomoći.</p>
      <div class="mt-8">
        <a href="/hr/contact" class="btn-primary">Rezervirajte 30-minutni uvodni razgovor</a>
      </div>
    </div>
  </section>
</BaseLayout>
