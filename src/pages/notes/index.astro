---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.localeCompare(a.data.publishedAt));
---
<BaseLayout
  title="Notes — Thinking Machine"
  description="Cross-domain notes on engineering, integration, cost, and compliance — the kind of analogies we'd actually make on a call. Healthcare to IoT, energy to SaaS, telco to fintech."
  pageType="CollectionPage"
>
  <section class="container-page pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden">
    <svg aria-hidden="true" class="absolute -top-20 -right-32 w-[420px] h-[420px] opacity-[0.04] pointer-events-none" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <path d="M30 100 Q100 30 170 100 T170 100" stroke="#1E3A8A" stroke-width="1" fill="none"/>
      <path d="M30 130 Q100 60 170 130" stroke="#1E3A8A" stroke-width="1" fill="none"/>
      <path d="M30 70 Q100 0 170 70" stroke="#1E3A8A" stroke-width="1" fill="none"/>
    </svg>
    <div class="relative max-w-3xl">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-6 font-medium">Notes</div>
      <h1 class="font-serif text-4xl md:text-6xl text-ink-900 leading-[1.05] tracking-tight">
        Cross-domain analogies we make on calls.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-ink-700 leading-relaxed">
        Short essays on patterns that travel between sectors. Healthcare integration into IoT. Energy NFR practice into SaaS. The kind of thing we'd say on a thirty-minute call, written down.
      </p>
    </div>
  </section>

  <section class="container-page py-16 md:py-20">
    <div class="grid gap-6 md:grid-cols-2">
      {notes.map(n => (
        <a href={`/notes/${n.slug}`} class="block border border-ink-200 bg-white p-7 md:p-8 card-lift no-underline group">
          <div class="text-xs uppercase tracking-wider text-ink-500 mb-3">
            {new Date(n.data.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })} · {n.data.tags.slice(0, 3).join(' · ')}
          </div>
          <h2 class="font-serif text-2xl text-ink-900 leading-tight group-hover:text-accent-800 transition-colors">{n.data.title}</h2>
          <p class="mt-4 text-ink-700">{n.data.summary}</p>
          <span class="inline-flex items-center gap-1 mt-5 text-sm text-accent-700">
            Read note <span class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  {/* Selected writing elsewhere — link out to other publishing venues */}
  <section class="container-page pb-12">
    <div class="border-t border-ink-200 pt-12 max-w-prose">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">Selected writing elsewhere</div>
      <p class="text-ink-700 leading-relaxed">
        Long-form notes live here. Shorter pieces and personal-voice essays appear from time to time on <a href="https://medium.com/@bruno.bozic" rel="noopener" class="text-accent-700 no-underline">Medium</a> and <a href="https://www.linkedin.com/in/bruno-bo%C5%BEi%C4%87-74245876/recent-activity/articles/" rel="noopener" class="text-accent-700 no-underline">LinkedIn Articles</a>. Where the same idea is published in two places, the canonical version is the one on this page; the cross-post acknowledges it.
      </p>
    </div>
  </section>

  <section class="container-page pb-24">
    <div class="border-t border-ink-200 pt-12 max-w-prose">
      <p class="text-ink-700 leading-relaxed">
        New notes are added when a cross-domain pattern is fresh enough to be useful. We do not run a newsletter; if you want a ping when new notes ship, subscribe to the <a href="/rss.xml" class="text-accent-700 no-underline">RSS feed</a> or watch the <a href="https://github.com/brunobozic/thinkingmachine-site" class="text-accent-700 no-underline" rel="noopener">repository on GitHub</a>.
      </p>
    </div>
  </section>
</BaseLayout>
