---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map(n => ({ params: { slug: n.slug }, props: { note: n } }));
}

interface Props { note: CollectionEntry<'notes'>; }
const { note } = Astro.props;
const { Content } = await note.render();
const { title, summary, publishedAt, tags } = note.data;
---
<BaseLayout
  title={`${title} — Thinking Machine Notes`}
  description={summary}
  pageType="Article"
>
  <article class="container-page py-16 md:py-24">
    <nav class="max-w-prose mx-auto mb-8 text-sm">
      <a href="/notes" class="text-ink-500 hover:text-ink-900 no-underline">← All notes</a>
    </nav>
    <header class="max-w-prose mx-auto mb-12">
      <div class="text-xs uppercase tracking-wider text-ink-500 mb-4">
        {new Date(publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })} · {tags.join(' · ')}
      </div>
      <h1 class="font-serif text-3xl md:text-5xl text-ink-900 leading-[1.15]">{title}</h1>
      <p class="mt-6 text-lg text-ink-700 italic font-serif leading-relaxed">{summary}</p>
    </header>
    <section class="prose mx-auto"><Content /></section>
    <hr class="section-divider mx-auto max-w-prose" />
    <section class="max-w-prose mx-auto">
      <p class="font-serif text-2xl text-ink-900 leading-snug">Want this kind of cross-domain read on your problem?</p>
      <p class="mt-4 text-ink-700">The first thirty minutes is on us — no pitch, no slides.</p>
      <div class="mt-6"><a href="/contact" class="btn-primary">Book a 30-minute intro</a></div>
    </section>
  </article>
</BaseLayout>
