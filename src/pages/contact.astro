---
import BaseLayout from '../layouts/BaseLayout.astro';

// Booking primitive. Set CAL_BOOKING_PATH to your cal.com event path (e.g.
// "thinkingmachine/intro") to switch from mailto: to a real Cal.com embed.
// Leaving it empty keeps the mailto: fallback.
//
// When CAL_BOOKING_PATH is set, ALSO update the CSP in
// infra/traefik/dynamic.yml to allow cal.com:
//   script-src ... https://app.cal.com 'unsafe-inline'
//   frame-src https://app.cal.com
//   connect-src 'self' https://api.cal.com https://app.cal.com
// Cal.com loads its embed iframe from app.cal.com and the API from api.cal.com.
const CAL_BOOKING_PATH = ''; // e.g. 'thinkingmachine/intro' — empty = mailto fallback

const emailAddress = 'hello@thinkingmachine.uk';
const mailtoSchedule = `mailto:${emailAddress}?subject=Intro%20call%20%E2%80%94%20Thinking%20Machine&body=Hi%20Bruno%2C%0A%0AI%27d%20like%20to%20book%20a%2030-minute%20intro.%20A%20few%20sentences%20on%20the%20problem%3A%0A%0A%5Bproblem%5D%0A%0AGood%20times%20for%20me%20%28with%20timezone%29%3A%0A%0A%5Bslots%5D%0A%0AThanks%2C%0A%5Bname%5D`;
const useCalEmbed = CAL_BOOKING_PATH.length > 0;
---
<BaseLayout
  title="Contact — Thinking Machine"
  description="Book a free 30-minute introduction. No slides, no pitch. We discuss your problem and decide together whether we can help."
  pageType="ContactPage"
>
  <section class="container-page pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden">
    <svg aria-hidden="true" class="absolute -top-20 -right-32 w-[420px] h-[420px] opacity-[0.04] pointer-events-none" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <circle cx="60" cy="60" r="40" stroke="#1E3A8A" stroke-width="1" fill="none"/>
      <circle cx="140" cy="140" r="40" stroke="#1E3A8A" stroke-width="1" fill="none"/>
      <line x1="60" y1="60" x2="140" y2="140" stroke="#1E3A8A" stroke-width="1"/>
    </svg>
    <div class="relative max-w-3xl">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-6 font-medium">Contact</div>
      <h1 class="font-serif text-4xl md:text-6xl text-ink-900 leading-[1.05] tracking-tight">
        Thirty minutes. No slides. No pitch.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-ink-700 leading-relaxed">
        The first call is always free. We use it to understand the problem and decide together whether we can help. If we don't think Thinking Machine is the right fit, we will say so on the call and, where possible, point you to someone better suited.
      </p>
    </div>
  </section>

  {useCalEmbed ? (
    /* Cal.com inline embed — appears once CAL_BOOKING_PATH is configured.
       The widget is GDPR-compliant; Cal.com is EU-friendly and the embed
       only loads after this section is reached (no global third-party
       script in BaseLayout). */
    <section class="container-page py-12 md:py-16 max-w-page">
      <div class="grid md:grid-cols-3 gap-8 mb-8">
        <div class="md:col-span-1">
          <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4 font-medium">Schedule</div>
          <h2 class="font-serif text-3xl text-ink-900 leading-tight">Pick a slot.</h2>
          <p class="mt-5 text-ink-700 leading-relaxed">
            Thirty minutes via video. No slides, no pitch. Confirmation lands in your inbox immediately.
          </p>
          <p class="mt-4 text-sm text-ink-500">
            Prefer email? Write to <a href={`mailto:${emailAddress}`} class="text-accent-700 no-underline">{emailAddress}</a> — we reply within one working day.
          </p>
        </div>
        <div class="md:col-span-2 border border-ink-200 bg-white p-1">
          <div data-cal-link={CAL_BOOKING_PATH} data-cal-namespace="intro" data-cal-config='{"layout":"month_view"}' style="min-height:640px;"></div>
        </div>
      </div>
      <script is:inline define:vars={{ CAL_BOOKING_PATH }}>
        (function(C,A,L){let p=function(a,ar){a.q.push(ar);};let d=C.document;C.Cal=C.Cal||function(){let cal=C.Cal;let ar=arguments;if(!cal.loaded){cal.ns={};cal.q=cal.q||[];d.head.appendChild(d.createElement("script")).src=A;cal.loaded=true;}if(ar[0]===L){const api=function(){p(api,arguments);};const namespace=ar[1];api.q=api.q||[];typeof namespace==="string"?(cal.ns[namespace]=api)&&p(api,ar):p(cal,ar);return;}p(cal,ar);};})(window,"https://app.cal.com/embed/embed.js","init");
        Cal("init","intro",{origin:"https://cal.com"});
        Cal.ns.intro("ui",{styles:{branding:{brandColor:"#1E3A8A"}},hideEventTypeDetails:false,layout:"month_view"});
      </script>
    </section>
  ) : (
    /* Mailto fallback — active when CAL_BOOKING_PATH is empty. */
    <section class="container-page py-12 md:py-16 grid md:grid-cols-2 gap-12 max-w-page">
      <div class="bg-accent-700 text-white p-10 md:p-12">
        <div class="text-xs uppercase tracking-[0.2em] opacity-70 mb-4 font-medium">Schedule</div>
        <h2 class="font-serif text-3xl text-white leading-tight">Pick a slot that works.</h2>
        <p class="mt-5 opacity-90 leading-relaxed">
          Thirty minutes via video. Send a few sentences on the problem and proposed times — we will reply within one working day with a calendar invite.
        </p>
        <a href={mailtoSchedule} class="inline-block mt-8 bg-white text-accent-700 px-6 py-3 no-underline hover:bg-ink-50 transition-colors font-medium">
          Email to schedule →
        </a>
      </div>

      <div class="bg-ink-100/40 border border-ink-200 p-10 md:p-12">
        <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4 font-medium">Email</div>
        <h2 class="font-serif text-3xl text-ink-900 leading-tight">Or write first.</h2>
        <p class="mt-5 text-ink-700 leading-relaxed">
          If the calendar isn't loading, or you want to send some context ahead, drop a line. We reply within one working day.
        </p>
        <a href={`mailto:${emailAddress}`} class="inline-block mt-8 text-accent-700 no-underline text-lg">
          {emailAddress} →
        </a>
      </div>
    </section>
  )}

  {/* What to expect — 5-step buyer-journey flow */}
  <section class="container-page py-16 md:py-20">
    <div class="max-w-2xl mb-10">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-700 mb-4">What to expect</div>
      <h2 class="font-serif text-3xl md:text-4xl text-ink-900 leading-tight">From first email to final readout.</h2>
      <p class="mt-4 text-ink-700 leading-relaxed">
        The path from initial contact to a delivered engagement, in five steps. Step 1 is free. Step 2 quotes a fixed fee — no commitment until you sign.
      </p>
    </div>
    <div class="bg-white border border-ink-200 p-6 md:p-10">
      <svg viewBox="0 0 760 200" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" role="img" aria-labelledby="flow-title flow-desc">
        <title id="flow-title">Buyer journey from first contact to engagement readout</title>
        <desc id="flow-desc">A horizontal five-step flow. Step 1: 30-minute intro call, free, no NDA needed. Step 2: fixed-fee quote within two working days, NDA signed first if you prefer. Step 3: kickoff call, scope confirmed. Step 4: engagement runs, one to four weeks depending on shape. Step 5: final readout, deliverables handed over.</desc>

        <defs>
          <marker id="arrow-flow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" fill="#1E3A8A"/>
          </marker>
        </defs>

        {/* connecting arrows between nodes */}
        <line x1="148" y1="100" x2="180" y2="100" stroke="#1E3A8A" stroke-width="1.5" marker-end="url(#arrow-flow)"/>
        <line x1="300" y1="100" x2="332" y2="100" stroke="#1E3A8A" stroke-width="1.5" marker-end="url(#arrow-flow)"/>
        <line x1="452" y1="100" x2="484" y2="100" stroke="#1E3A8A" stroke-width="1.5" marker-end="url(#arrow-flow)"/>
        <line x1="604" y1="100" x2="636" y2="100" stroke="#1E3A8A" stroke-width="1.5" marker-end="url(#arrow-flow)"/>

        {/* Step 1: 30-min intro call */}
        <g>
          <circle cx="76" cy="100" r="36" fill="#1E3A8A"/>
          <text x="76" y="96" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="600" fill="white">Step 1</text>
          <text x="76" y="112" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="white" opacity="0.85">30-min call</text>
          <text x="76" y="160" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#3F3F46">Free, no slides</text>
          <text x="76" y="174" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#3F3F46">NDA on request</text>
        </g>

        {/* Step 2: Fixed-fee quote */}
        <g>
          <circle cx="228" cy="100" r="36" fill="white" stroke="#1E3A8A" stroke-width="2"/>
          <text x="228" y="96" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="600" fill="#18181B">Step 2</text>
          <text x="228" y="112" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="#52525B">Fixed-fee quote</text>
          <text x="228" y="160" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#3F3F46">Within 2 working</text>
          <text x="228" y="174" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#3F3F46">days, no expansion</text>
        </g>

        {/* Step 3: Kickoff */}
        <g>
          <circle cx="380" cy="100" r="36" fill="white" stroke="#1E3A8A" stroke-width="2"/>
          <text x="380" y="96" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="600" fill="#18181B">Step 3</text>
          <text x="380" y="112" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="#52525B">Kickoff</text>
          <text x="380" y="160" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#3F3F46">Scope confirmed,</text>
          <text x="380" y="174" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#3F3F46">interview targets agreed</text>
        </g>

        {/* Step 4: Engagement */}
        <g>
          <circle cx="532" cy="100" r="36" fill="white" stroke="#1E3A8A" stroke-width="2"/>
          <text x="532" y="96" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="600" fill="#18181B">Step 4</text>
          <text x="532" y="112" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="#52525B">Engagement</text>
          <text x="532" y="160" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#3F3F46">1–4 weeks,</text>
          <text x="532" y="174" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#3F3F46">midpoint review at week 2</text>
        </g>

        {/* Step 5: Readout */}
        <g>
          <circle cx="684" cy="100" r="36" fill="#B45309"/>
          <text x="684" y="96" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="600" fill="white">Step 5</text>
          <text x="684" y="112" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" fill="white" opacity="0.85">Final readout</text>
          <text x="684" y="160" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#3F3F46">60-min walkthrough,</text>
          <text x="684" y="174" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#3F3F46">deliverables yours</text>
        </g>
      </svg>
      <p class="mt-6 pt-5 border-t border-ink-100 text-sm text-ink-700 leading-relaxed">
        Total elapsed from first email to engagement quote: usually under three working days. From kickoff to final readout: one to four weeks depending on engagement shape. The first thirty minutes is on us regardless of whether we proceed.
      </p>
    </div>
  </section>

  <section class="container-page py-12">
    <div class="prose max-w-prose">
      <h2>What to send ahead</h2>
      <p>A few sentences on the problem. The deadline if there is one. Any documents that frame the question. We will read what you send before the call.</p>
      <p>We treat all pre-engagement communications as confidential. We do not maintain a CRM. We do not subscribe you to a newsletter. We do not share your inquiry with anyone outside Thinking Machine.</p>

      <h2>Where we work</h2>
      <p>Zagreb, Croatia, with engagements across the European Union. Remote-first. We travel for kickoff and final-readout meetings when the engagement warrants it.</p>

      <h2>What we charge</h2>
      <p>Engagement fees depend on shape and scope; we will quote a fixed fee on the first call before any commitment. We do not bill hourly. There are no expansion clauses. We do not charge for the introductory thirty minutes regardless of outcome.</p>
    </div>
  </section>

  <section class="container-page pb-16">
    <hr class="section-divider mx-auto max-w-prose" />
    <footer class="max-w-prose text-sm text-ink-500">
      <p><strong class="text-ink-800">Thinking Machine d.o.o.</strong></p>
      <p>Zagreb, Croatia · Founded 2022</p>
      <p>OIB: <span class="text-ink-700">62472822484</span> · MB: <span class="text-ink-700">5637031</span></p>
      <p>Registered office: <span class="text-ink-700">Zagorska ulica 11, 10000 Zagreb, Croatia</span></p>
    </footer>
  </section>
</BaseLayout>
